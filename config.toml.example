# TRD Speak configuration
# Delete this file (or any section/key) to fall back to the built-in defaults,
# which are the same values shown below.

[hotkey]
# Keys that must ALL be held simultaneously to record. Release any one of
# them to stop recording and transcribe.
#
# Must be 2 or 3 DIFFERENT keys, and at least one of them must be a modifier
# (ctrl, alt, cmd, or shift). A 1-key shortcut (e.g. keys = ["v"]), a combo
# with no modifier (e.g. keys = ["v", "b"]), or the same key repeated (e.g.
# keys = ["ctrl", "ctrl"], which is really only one key) is unusable as a
# global hotkey — it would fire on every press of that key/combo anywhere on
# the system — so it is rejected at startup, this shortcut falls back to its
# default, and a warning is logged. The same rule applies to the [repaste]
# combo below and to the "correct" shortcut (cmd+alt by default; not shown
# in this example file, set via [correct] keys = [...] or the settings
# window), and to the settings-window "Configuration…" panel.
#
# Valid key names:
#   Modifiers:  "ctrl", "alt" (alias "option"), "cmd" (alias "command"), "shift"
#   Arrows:     "right", "left", "up", "down"
#   Others:     "space", "tab", "enter", "esc", "f1" .. "f20"
#   Or any single character, e.g. "z"
#
# Modifier-only combos (like the default ctrl+shift) are the most reliable on
# macOS: they don't type anything into the focused app. Note: ctrl+right
# conflicts with the default Mission Control "Move right a space" shortcut —
# avoid it unless you have changed that shortcut in System Settings. Must NOT
# resolve to the same key set as the [repaste] combo below or the "correct"
# shortcut — if two combos collide, the lower-priority one (dictate wins over
# repaste, which wins over correct) falls back to its default and a warning
# is logged, so pressing that combo does not fire both actions at once.
#
# You can also set this shortcut from the menu's "Configuration…" panel
# (under "Recent Dictations") by pressing the combo you want. That choice is
# saved to ~/Library/Application Support/TRD Speak/hotkeys.json and takes
# precedence over the value here, the same way the engine choice does.
keys = ["ctrl", "shift"]

[repaste]
# Keys for the "re-paste the last dictation" shortcut. If a dictation lands in
# the wrong window, switch to the right one and TAP this combo (press and
# release without pressing anything else) to insert your most recent dictation
# there. Same key names and 2-to-3-key-plus-modifier rule as [hotkey] above.
#
# The default cmd+ctrl is only two keys, so it is a little easier to trigger by
# accident than a three-key combo — but the tap rule keeps the common cases
# safe: pressing any other key during the hold (e.g. Cmd+Ctrl+Space for the
# emoji picker, or Cmd+Ctrl+F for fullscreen) cancels the re-paste.
#
# This shortcut can also be set from the menu's "Configuration…" panel; the
# recorded combo is saved to ~/Library/Application Support/TRD Speak/hotkeys.json
# and takes precedence over the value here (same model as [hotkey] above).
keys = ["cmd", "ctrl"]

[engine]
# Transcription engine. Currently only "whisper" (faster-whisper, CPU, light)
# is available.
name = "whisper"

[whisper]
# faster-whisper model to use. "base.en" is fast on Apple Silicon CPUs with
# good accuracy for clear speech. Alternatives: "tiny.en" (fastest),
# "small.en" / "medium.en" (more accurate, slower and more RAM).
# English-only models recommended.
model = "base.en"
# Quantization used for CPU inference. "int8" is fastest and lightest.
compute_type = "int8"
# Decoding beam width. 1 (greedy) is what realtime dictation tools use and is
# several times faster; raise to e.g. 5 for slightly more careful decoding at
# a big speed cost on long recordings.
beam_size = 1

[recording]
# Maximum recording length in seconds. Audio beyond this is dropped.
max_seconds = 180
# Microphone sample rate in Hz. Whisper expects 16000; leave as is.
sample_rate = 16000

[paste]
# Seconds to wait after synthesizing Cmd+V before restoring your previous
# clipboard contents. Increase if pastes occasionally come out as your old
# clipboard text (the target app was slow to read the clipboard).
restore_delay = 0.4
